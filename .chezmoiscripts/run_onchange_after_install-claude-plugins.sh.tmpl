#!/usr/bin/env bash
command -v claude >/dev/null || { echo "claude not on PATH, skipping plugin install"; exit 0; }

installed_plugins="$HOME/.claude/plugins/installed_plugins.json"
known_marketplaces="$HOME/.claude/plugins/known_marketplaces.json"

{{ if hasKey .claude "marketplaces" }}{{ range $name, $source := .claude.marketplaces -}}
if ! [ -f "$known_marketplaces" ] || ! jq -e --arg m {{ $name | quote }} '.[$m]' "$known_marketplaces" >/dev/null; then
  claude plugin marketplace add {{ $source | quote }}
fi
claude plugin marketplace update {{ $name | quote }}
{{ end -}}{{ end -}}

{{ if hasKey .claude "plugins" }}{{ range .claude.plugins -}}
if ! [ -f "$installed_plugins" ] || ! jq -e --arg p {{ . | quote }} '.plugins[$p]' "$installed_plugins" >/dev/null; then
  claude plugin install {{ . | quote }}
fi
{{ end -}}{{ end -}}

# XDG Base Directories — set defaults but respect anything already exported.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"

# Move ZDOTDIR off $HOME so .zshrc/.zprofile/.zsh_history live under XDG.
export ZDOTDIR="$XDG_CONFIG_HOME/zsh"

{{ if eq .chezmoi.os "darwin" -}}
# Relocate the per-tty session blobs Apple's /etc/zshrc_Apple_Terminal writes.
export SHELL_SESSION_DIR="$XDG_STATE_HOME/zsh/sessions"
{{- end }}

# EDITOR/VISUAL: prefer nvim, fall back to vim. Set in .zshenv (not .zshrc) so
# subprocesses (git commit, crontab -e) inherit them from non-interactive shells.
if (( $+commands[nvim] )); then
    export EDITOR=nvim VISUAL=nvim
elif (( $+commands[vim] )); then
    export EDITOR=vim VISUAL=vim
fi

# Ensure the directories the rest of the config writes to exist.
[[ -d "$XDG_STATE_HOME/zsh" ]] || mkdir -p "$XDG_STATE_HOME/zsh"
[[ -d "$XDG_CACHE_HOME/zsh" ]] || mkdir -p "$XDG_CACHE_HOME/zsh"
{{ if eq .chezmoi.os "darwin" -}}
[[ -d "$SHELL_SESSION_DIR" ]] || mkdir -p "$SHELL_SESSION_DIR"
{{- end }}
